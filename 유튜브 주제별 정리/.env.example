YOUTUBE_API_KEY=your-youtube-data-api-key
CHANNEL_CONFIG_PATH=config/channels.yaml
OPENAI_API_KEY=your-openai-api-key

GOOGLE_SPREADSHEET_ID=your-google-sheet-id
GOOGLE_SHEET_NAME=__RUN_TIMESTAMP__

# Prefer this in GitHub Actions. Paste the full service account JSON as one secret.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Alternative for local runs.
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Optional only when using Google Sheets OAuth instead of service account JSON.
# YOUTUBE_CLIENT_ID=your-google-oauth-client-id
# YOUTUBE_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_SHEETS_REFRESH_TOKEN=your-google-sheets-refresh-token

# Use keyword-based fallback when OpenAI quota is unavailable.
# ALLOW_RULE_BASED_CLASSIFIER=true
